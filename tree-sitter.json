{
  "grammars": [
    {
      "name": "surrealql",
      "camelcase": "Surrealql",
      "scope": "source.surrealql",
      "path": ".",
      "file-types": ["surql"],
      "highlights": ["queries/highlights.scm"],
      "folds": ["queries/folds.scm"],
      "indents": ["queries/indents.scm"]
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "Apache-2.0",
    "description": "Tree-sitter grammar for SurrealQL (SurrealDB 3+)",
    "authors": [
      {
        "name": "overrealdb"
      }
    ],
    "links": {
      "repository": "https://github.com/overrealdb/tree-sitter-surrealql"
    }
  },
  "bindings": {
    "c": true,
    "node": true,
    "rust": true
  }
}
